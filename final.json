[{"body": "PT Indofood CBP Sukses Makmur Tbk (ICBP) reported a 8.14% year-on-year increase in net sales to IDR 55.5 trillion and a 15.6% year-on-year increase in net profit to IDR 9.37 trillion in September 2024, demonstrating stable financial performance despite challenges. The company's commitment to social programs, such as the Indofood Riset Nugraha (IRN) initiative, has also led to a 29% growth in research proposals from students, with over 600 proposals from 84 universities.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 2, "ownership": 0, "sustainability": 1, "technical": 0, "valuation": 0}, "score": 75, "sector": "consumer-non-cyclicals", "source": "https://www.idnfinancials.com/news/51466/strong-commitment-indofood-riset-nugraha-program-anthoni-salim-awarded-ceo", "sub_sector": ["food-beverage"], "tags": ["Earnings Report", "IDX", "Bullish"], "tickers": ["ICBP.JK"], "timestamp": "2024-11-15T17:20:29", "title": "Anthoni Salim, President Director of Indofood, receives Best CEO award for outstanding support of student academic research through Indofood Riset Nugraha initiative."}, {"body": "PT Indofood Sukses Makmur Tbk (INDF) reported strong financial performance, with revenue reaching IDR 86.9 trillion and profits increasing to IDR 12.3 trillion as of September 2024, demonstrating the company's robust financial health. Under Anthoni Salim's leadership, INDF has consistently posted strong revenue and profit growth, with assets and equity reaching IDR 195.5 trillion and IDR 107.9 trillion, respectively, as of September 2024.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 2, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "consumer-non-cyclicals", "source": "https://www.idnfinancials.com/news/51465/bringing-indofood-world-anthoni-salim-named-ceo", "sub_sector": ["food-beverage"], "tags": ["Earnings Report", "IDX", "Bullish"], "tickers": ["INDF.JK"], "timestamp": "2024-11-15T17:16:51", "title": "Anthoni Salim, President Director of Indofood, Receives Best CEO Award for Transforming Company into Global Total Food Solution Enterprise."}, {"body": "PT Metrodata Electronics Tbk (MTDL) has been recognized for its commitment to advancing digital literacy, with President Director Susanto Djaja receiving the Best CEO award from Tempo-IDNFinancials, acknowledging the company's initiatives and strong leadership. The company has reported a net profit of IDR 445.41 billion as of September 30, 2024, a 10.8% year-on-year increase, and has been selected as a constituent of the Indeks52, with a compound annual growth rate of 12.75% over the last four years.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 2, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "technology", "source": "https://www.idnfinancials.com/news/51464/susanto-djaja-wins-ceo-award-commitment-enhancing-digital-literacy", "sub_sector": ["technology-hardware-equipment"], "tags": ["IDX", "Earnings Report", "Executive Changes", "Market Analysis", "Financial Ratios", "Bullish"], "tickers": ["MTDL.JK"], "timestamp": "2024-11-15T17:13:45", "title": "Metrodata Electronics' President Director Susanto Djaja Receives Best CEO Award for Advancing Digital Literacy"}, {"body": "Adira Finance (ADMF) has expanded its financing portfolio, disbursing IDR 10.1 trillion (24.3% of its total portfolio) to micro, small, and medium enterprises (MSMEs) by the end of 2023, and has seen an 8.89% year-on-year revenue increase to IDR 7.5 trillion as of September 2024. This commitment to financial inclusion has earned Made Dewa Susila, President Director of Adira Finance, the Best CEO title at the Top CEO Indonesia Awards 2024.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 2, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "financials", "source": "https://www.idnfinancials.com/news/51463/promoting-social-loans-mufg-dewa-susila-wins-ceo-award", "sub_sector": ["financing-service"], "tags": ["Financial Ratios", "Earnings Report", "IDX", "Fintech", "Executive Changes", "Bullish"], "tickers": [], "timestamp": "2024-11-15T17:09:43", "title": "Adira Finance's President Director Made Dewa Susila Wins Best CEO Award for Social Loan Initiatives."}, {"body": "PT Pandai Indah Kapuk Dua Tbk (PANI) has reported a 91% year-on-year net profit increase to IDR 487 billion, with revenues reaching IDR 2.1 trillion and pre-sales amounting to IDR 4.7 trillion, achieving 78% of its 2024 target. The company's assets have surged to IDR 44.2 trillion, with equity reaching IDR 26.2 trillion, following a private placement of IDR 6.5 trillion in August, and management has revised its pre-sale target upward to IDR 6 trillion from IDR 5.5 trillion.", "dimension": {"dividend": 0, "financials": 2, "future": 2, "management": 1, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 2}, "score": 75, "sector": "financials", "source": "https://www.idnfinancials.com/news/51462/transforming-pik-sugianto-kusuma-named-ceo", "sub_sector": ["investment-service", "banks", "insurance", "insurance"], "tags": ["Earnings Report", "IDX", "Financial Ratios", "Balance Sheets", "Market Trends", "Bullish"], "tickers": ["PANS.JK", "PNBS.JK", "PNIN.JK", "PNLF.JK"], "timestamp": "2024-11-15T17:05:51", "title": "Sugianto Kusuma, CEO of PT Pandai Indah Kapuk Dua, Wins Award for Outstanding Township Development in Indonesia."}, {"body": "PT Bank Rakyat Indonesia Tbk (BBRI) reported a credit portfolio of IDR 1,266 trillion in December 2023, with 67.1% (IDR 777.28 trillion) allocated to sustainable financing, positioning it as a leader in Indonesia's banking industry. Under President Director Sunarso's leadership, BBRI has consistently posted solid financial performance, with a 4.5% year-on-year increase in net revenue to IDR 105.76 trillion and a 2.6% year-on-year increase in net profit to IDR 45.36 trillion as of September 2024.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 1, "ownership": 0, "sustainability": 2, "technical": 0, "valuation": 0}, "score": 75, "sector": "financials", "source": "https://www.idnfinancials.com/news/51456/sunarso-recognized-ceo-expanding-sustainable-credit-portfolio", "sub_sector": ["banks"], "tags": ["Earnings Report", "Financial Ratios", "IDX", "Market Analysis", "Bullish"], "tickers": ["BBRI.JK"], "timestamp": "2024-11-15T16:24:20", "title": "Bank Rakyat Indonesia's President Director Sunarso Wins Award for Sustainable Financing Efforts"}, {"body": "PT Bank Central Asia Tbk (BCA) reported a 3.8% year-on-year increase in assets to IDR 1.43 quadrillion and a 14.5% surge in lending to IDR 877 trillion as of September 2024, with net interest income rising 9.5% to IDR 61.1 trillion and net profit increasing 12.8% to IDR 41.1 trillion. CEO Jahja Setiaatmadja received the Best CEO Special Mention award for his commitment to addressing stunting in Indonesia, marking another accolade for the bank, which has consistently performed well and remains a constituent of the Indeks52 stock index.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 1, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "financials", "source": "https://www.idnfinancials.com/news/51455/jahja-setiaadmadja-ceos", "sub_sector": ["banks", "food-beverage", "oil-gas-coal", "retailing", "heavy-constructions-civil-engineering", "heavy-constructions-civil-engineering", "financing-service", "oil-gas-coal", "oil-gas-coal", "basic-materials", "banks", "banks", "food-beverage", "oil-gas-coal", "insurance", "banks", "industrial-goods", "basic-materials", "investment-service", "food-staples-retailing", "food-beverage", "basic-materials", "holding-investment-companies", "properties-real-estate", "basic-materials", "utilities", "properties-real-estate", "indus