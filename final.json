[{"body": "The Jakarta Stock Price Composite Index (IHSG) rose 0.22% or 16.14 points to 7,329.46, driven by gains in sectors such as technology, property, and finance, with PT Adaro Andalan Indonesia TBK (ADRO) and PT Tempo Inti Media TBK (TEGU) among the top gainers. Meanwhile, PT Ulima Nitra TBK (ULIMA) led the losers, falling 12.24%, followed by PT Indo Straits TBK (INTS) and PT Techno9 Indonesia TBK (TECH).", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 2, "valuation": 0}, "score": 65, "sector": "consumer-cyclicals", "source": "https://www.idnfinancials.com/news/51672/ihsg-regains-strength-declines-sectors", "sub_sector": ["media-entertainment", "oil-gas-coal", "oil-gas-coal", "technology-hardware-equipment"], "tags": ["IDX Composite", "IDX", "Market Trends", "Market Sentiment", "Bullish"], "tickers": ["TMPO.JK", "UNIQ.JK", "PTIS.JK", "NINE.JK"], "timestamp": "2024-12-06T13:35:36", "title": "Jakarta Stock Price Composite Index Rises 0.22% to 7,329.46 Points Amid Sector Gains"}, {"body": "UOB Kay Hian Ltd acquired 21.75% of PT Apexindo Pratama Duta Tbk's shares, while PT Aserra Capital sold 31.76% of its shares, and PT Techno9 Indonesia Tbk saw a change in ownership with Noprian Fadli acquiring 12% of its shares. Meanwhile, foreign investors such as CGS International Securities Singapore Pte Ltd and Anderson Bay Pte Ltd made significant purchases in PT Astrindo Nusantara Infrastruktur Tbk and PT Exploitasi Energi Indonesia Tbk, respectively.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "technology", "source": "https://www.idnfinancials.com/news/51671/hong-kong-based-uob-kay-hian-purchases-apexindo-apex-stock", "sub_sector": ["technology-hardware-equipment", "oil-gas-coal"], "tags": ["Mergers & Acquisitions", "Foreign Investor", "Bullish"], "tickers": ["NINE.JK", "BIPI.JK"], "timestamp": "2024-12-06T12:53:57", "title": "Foreign investors acquire significant stakes in several Indonesian companies across various sectors."}, {"body": "PT Sido Muncul Tbk's stock price has increased 7.40% since December 8, 2023, to IDR 850 per share, but still declined 24.18% from December 9, 2022, and 66.66% from December 10, 2021. The company's stock peaked at IDR 1,040 on March 18, 2022, during the COVID-19 pandemic, but has since experienced a gradual decline.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 2, "valuation": 2}, "score": 65, "sector": "healthcare", "source": "https://www.idnfinancials.com/news/51670/golden-era-sido-end", "sub_sector": ["pharmaceuticals-health-care-research"], "tags": ["IDX", "IDX Composite", "Market Trends", "Bearish"], "tickers": ["SIDO.JK"], "timestamp": "2024-12-06T11:31:44", "title": "PT Sido Muncul's stock price shows mixed performance with gradual decline since 2019 despite brief surge during COVID-19 pandemic."}, {"body": "Mataram Limited will acquire 98.11% of PT SLJ Global Tbk (SLJG) through a private placement, increasing its stake to 16.11% of the total 5.92 billion listed shares, valued at approximately 6.75% of the company's total shares. The controllers of Suli now hold 42.78% of shares, while non-controllers own 57.22%, with a free float of 1.83 billion shares or 30.91% of the total listed shares.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "basic-materials", "source": "https://www.idnfinancials.com/news/51669/mataram-limited-raise-portion-suli", "sub_sector": ["basic-materials", "food-beverage", "oil-gas-coal", "retailing", "heavy-constructions-civil-engineering", "heavy-constructions-civil-engineering", "financing-service", "oil-gas-coal", "oil-gas-coal", "basic-materials", "banks", "bank