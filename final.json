[{"body": "PT Smartfren Telecom Tbk (FREN) maintained its top spot on the net foreign buy list, with a net foreign buy of 116.59 million shares, and its stock price closed at Rp23 per share, up Rp1 from the previous day. PT Bank Rakyat Indonesia Tbk (BBRI) ranked second, with a net foreign buy of 108.18 million shares, and its stock price closed at Rp4,090, up from the previous day's closing price of Rp3,800.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 2, "valuation": 0}, "score": 75, "sector": "infrastructures", "source": "https://www.idnfinancials.com/news/52069/fren-bbri-foreign-investors-favourites", "sub_sector": ["telecommunication", "banks"], "tags": ["IDX", "Foreign Investor", "Market Trends", "Bullish"], "tickers": ["FREN.JK", "BBRI.JK"], "timestamp": "2025-01-15T18:19:00", "title": "PT Smartfren Telecom and PT Bank Rakyat Indonesia top net foreign buy list at Indonesian stock market."}, {"body": "Bank Indonesia reported a 36.1% year-on-year growth in digital payments in 2024, with a total of 34.5 billion transactions, driven by a 175.2% surge in QRIS transactions and a 62.4% increase in BI-FAST retail transaction volumes. The central bank expects digital payments to grow 52.3% in 2025, with BI-FAST transaction volumes rising 34.1% and BI-RTGS transactions increasing 11.4% year-on-year.", "dimension": {"dividend": 0, "financials": 2, "future": 2, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "financials", "source": "https://www.idnfinancials.com/news/52068/qris-transaction-volume-surge", "sub_sector": ["banks", "banks", "banks", "banks"], "tags": ["Fintech", "Bullish"], "tickers": ["BBHI.JK", "BNII.JK", "MCOR.JK", "BBSI.JK"], "timestamp": "2025-01-15T18:06:13", "title": "Bank Indonesia reports 36.1% year-on-year growth in digital economic financial transactions in 2024, driven by increased use of QRIS and BI-FAST."}, {"body": "Bank Indonesia reduced its BI rate by 25 basis points to 5.75% from 6%, and also lowered its deposit facility rate to 5% and lending facility rate to 6.50%, citing projected low inflation of 2.5\u00b11% in 2025-2026. The central bank aims to maintain inflation within its target range, support economic growth, and promote job creation, particularly in priority sectors such as MSMES and the green economy.", "dimension": {"dividend": 0, "financials": 0, "future": 2, "management": 0, "ownership": 0, "sustainability": 2, "technical": 0, "valuation": 0}, "score": 75, "sector": "financials", "source": "https://www.idnfinancials.com/news/52067/rate-drops", "sub_sector": ["banks", "banks", "banks", "banks"], "tags": ["Interest Rates", "Inflation", "Bullish"], "tickers": ["BBHI.JK", "BNII.JK", "MCOR.JK", "BBSI.JK"], "timestamp": "2025-01-15T15:57:33", "title": "Bank Indonesia cuts interest rates to boost economic growth and maintain low inflation."}, {"body": "PT PP Properti Tbk (PPRO) remains suspended on the Indonesia Stock Exchange due to an ongoing debt restructuring process, following a payment delay of IDR 4.33 billion on its sustainable bond II phase IV year 2022 series B, which has a principal value of IDR 163.5 billion and an annual interest rate of 10.60%. The suspension will continue until further notice, with the exchange urging relevant parties to pay close attention to the company's information disclosure.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "properties-real-estate", "source": "https://www.idnfinancials.com/news/52066/bond-payment-deferred-ppro-suspension-extended", "sub_sector": ["properties-real-estate"], "tags": ["IDX", "Debt", "Bonds", "Bearish"], "tickers": ["PPRO.JK"], "timestamp": "2025-01-15T15:54:15", "title": "PT PP Properti's shares remain suspended on Indonesia Stock Exchange due to ongoing debt restructuring and payment delay."}, {"body": "Indonesia's total imports increased by 5.31% to USD 233.65 billion in 2024 compared to the same period in 2023, driven by a 1.24% rise in oil and gas sector imports and a 6.09% increase in non-oil and gas sector imports. In December 2024, total imports reached USD 21.22 billion, up 8.10% from November 2024, with oil and gas imports rising 28.26% to USD 3.29 billion and non-oil and gas imports increasing 5.06% to USD 17.92 billion.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "energy", "source": "https://www.idnfinancials.com/news/52065/total-imports-rose", "sub_sector": ["oil-gas-coal"], "tags": ["Inflation", "Economic Reports", "Market Trends", "Energy Commodities", "Neutral"], "tickers": [], "timestamp": "2025-01-15T15:28:31", "title": "Indonesia's total imports rise 5.31% in 2024 driven by increases in oil and non-oil gas sectors."}, {"body": "PT Pakuan Tbk (UANG) share price corrected to IDR 600 per share, extending its downtrend for the second day after the Indonesia Stock Exchange (IDX) lifted its suspension yesterday. The company's shares had been suspended since October 29, 2024, due to its failure to fulfill obligations, including issuing revisions to its financial reports for 2022 and 2023.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 2, "valuation": 0}, "score": 75, "sector": "properties-real-estate", "source": "https://www.idnfinancials.com/news/52059/suspension-lifted-uang-corrections", "sub_sector": ["properties-real-estate"], "tags": ["IDX", "IDX Composite", "Market Trends", "Bearish"], "tickers": ["UANG.JK"], "timestamp": "2025-01-15T09:58:23", "title": "PT Pakuan's share price continues to decline after Indonesia Stock Exchange lifts suspension."}, {"body": "PT Raharja Energi Cepu TBK (RATU) has been listed under unusual market activity by the Indonesia Stock Exchange due to its abnormal price surge of over 200% to IDR 4,330 per share, resulting in a price-earning ratio of 34.06, significantly higher than the industry average. The stock exchange authorities have taken this measure to ensure investor protection, but it does not necessarily indicate any violation of stock exchange regulations.", "dimension": {"dividend": 0, "financials": 1, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 2, "valuation": 2}, "score": 75, "sector": "energy", "source": "https://www.idnfinancials.com/news/52058/ratu-listed-uma-days-ara-overvalued", "sub_sector": ["alternative-energy"], "tags": ["IDX", "IDX Composite", "Market Trends", "Market Sentiment", "Interest Rates", "Neutral"], "tickers": [], "timestamp": "2025-01-15T09:55:59", "title": "Indonesia Stock Exchange Flags PT Raharja Energi Cepu for Unusual Market Activity Amid 200% Price Surge"}, {"body": "Indonesia's telecommunication sector experienced a 4% quarter-to-quarter and 5% year-on-year decline in average revenue per unit (ARPU) in Q3 2024, with PT XL Axiata Tbk (EXCL) feeling the most pressure with a 7% decline to IDR 41,000. Meanwhile, PT Telekomunikasi Seluler (TSel) and PT Indosat Tbk (ISAT) also saw ARPU declines of 4% and 3%, respectively, with only EXCL gaining 100,000 new users, while ISAT and TSEL lost 2.2 million and 1.5 million users, respectively.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "infrastructures", "source": "https://www.idnfinancials.com/news/52057/research-arpu-dropped-telecommunication-stocks-attractive", "sub_sector": ["telecommunication", "telecommunication"], "tags": ["Market Trends", "IDX", "Earnings Report", "Bearish"], "tickers": ["EXCL.JK", "ISAT.JK"], "timestamp": "2025-01-15T09:04:41", "title": "Telecommunication sector in Indonesia experiences revenue decline in Q3 2024, with major players such as XL Axiata, Telkomsel, and Indosat seeing a drop in average revenue per user."}, {"body": "The Jakarta Composite Stock Price Index (JCI) fell 0.86% or 60.21 points to 6,956.67 on Wednesday, its lowest level in 7 months, driven by declines in shares of PT Barito Renewables Energy Tbk (BREN), PT Bank Mandiri Tbk, and PT Bank Central Asia Tbk. The decline was also fueled by net foreign selling of IDR 633.22 billion, following a net sell of IDR 383.46 billion on Tuesday.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 1, "sustainability": 0, "technical": 2, "valuation": 2}, "score": 75, "sector": "infrastructures", "source": "https://www.idnfinancials.com/news/52055/jci-lowest-months", "sub_sector": ["utilities", "banks", "banks"], "tags": ["IDX Composite", "Market Trends", "Market Sentiment", "Foreign Investor", "IDX", "Bearish"], "tickers": ["BREN.JK", "BMRI.JK", "BBCA.JK"], "timestamp": "2025-01-15T07:26:23", "title": "Jakarta Composite Stock Price Index Falls to Lowest Level in 7 Months."}, {"body": "On Tuesday, January 14, foreign investors sold a net 832 million shares, with PT GoTo Gojek Tokopedia Tbk (GOTO) leading the sell list with 238.85 million shares, followed by PT Bukalapak.com Tbk (BUKA) with 176.86 million shares. Meanwhile, PT Smartfren Telecom Tbk (FREN) saw the largest net buy of 27 million shares, with PT Sumber Eneri Andalan Tbk (ITMA) and PT Pyridam Farma Tbk (PYFA) also experiencing net buys of around 12-13 million shares each.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 2, "valuation": 0}, "score": 75, "sector": "technology", "source": "https://www.idnfinancials.com/news/52054/foreign-sales-volume-remains-high-sell-shares", "sub_sector": ["software-it-services", "software-it-services", "telecommunication", "pharmaceuticals-health-care-research"], "tags": ["Foreign Investor", "IDX", "Bearish"], "tickers": ["GOTO.JK", "BUKA.JK", "FREN.JK", "PYFA.JK"], "timestamp": "2025-01-14T18:15:25", "title": "Foreign investors in Indonesia's stock market sell 832 million shares, led by PT GoTo Gojek Tokopedia TBK and PT Bukalapak.com TBK."}, {"body": "PT Hero Global Investment Tbk (HGII) has been acquired by Japan-based Shikoku Electric Power Company for 25% stake, with a total investment value of IDR 325 billion (approximately USD 22 million) through the purchase of 1.62 billion shares at IDR 200 each. This acquisition marks Yonden's first investment in a holding-level company in Indonesia, with HGII reporting a 22.3% year-on-year growth in net profit to IDR 26.3 billion at the end of Q1 2024.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "financials", "source": "https://www.idnfinancials.com/news/52053/conditions-met-yonden-close-officially-acquire-hgii", "sub_sector": ["holding-investment-companies"], "tags": ["Mergers & Acquisitions", "IDX", "Market Trends", "Bullish"], "tickers": [], "timestamp": "2025-01-14T17:22:50", "title": "Shikoku Electric Power Company Acquires 25% Stake in PT Hero Global Investment for IDR 325 Billion."}, {"body": "PT Vale Indonesia Tbk (INCO) has appointed Retno Lestari Priansari Marsudi, former Minister of Foreign Affairs, as an independent commissioner until 2027, replacing Raden Sukhyar, following an extraordinary general meeting of shareholders. The new board of commissioners now consists of seven commissioners and three independent commissioners, including Marsudi, with Muhammad Rachmat Kaimuddin as President Commissioner.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 2, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 65, "sector": "basic-materials", "source": "https://www.idnfinancials.com/news/52047/inco-assigns-retno-marsudi-independent-commissioner", "sub_sector": ["basic-materials"], "tags": ["Executive Changes", "IDX", "Neutral"], "tickers": ["INCO.JK"], "timestamp": "2025-01-14T13:40:11", "title": "Retno Marsudi, Former Foreign Minister, Appointed as Independent Commissioner of PT Vale Indonesia."}, {"body": "PT Siloam International Hospitals Tbk has submitted a non-binding letter of intent to acquire First REIT's hospital portfolio in Indonesia, which could potentially enhance Siloam's performance by reducing asset leasing costs. First REIT, a Singapore-based healthcare-focused investment company, is reviewing the letter of intent and considering its strategic options, with no definitive decision reached yet.", "dimension": {"dividend": 0, "financials": 1, "future": 1, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "healthcare", "source": "https://www.idnfinancials.com/news/52046/siloam-declares-acquiring-reit-hospitals", "sub_sector": ["healthcare-equipment-providers"], "tags": ["Mergers & Acquisitions", "IDX", "Market Trends", "Bullish"], "tickers": ["SILO.JK"], "timestamp": "2025-01-14T13:22:23", "title": "PT Siloam International Hospitals submits non-binding letter of intent to acquire First REIT's hospital portfolio in Indonesia."}, {"body": "PT Sariguna Primatirta Tbk (Cleo) aims to achieve double-digit growth by 2025, driven by its confidence in the Indonesian bottled water industry and rising awareness of healthy beverage consumption, with a track record of 20.3% average annual revenue growth since 2017. The company plans to expand its production, distribution, and operational efficiency, with three new factories and over 7,000 distribution partners, and has reported a 31.5% year-on-year sales growth and 60.8% net profit surge in Q3 2024.", "dimension": {"dividend": 0, "financials": 2, "future": 2, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "consumer-non-cyclicals", "source": "https://www.idnfinancials.com/news/52045/cleo-aims-double-digit-growth", "sub_sector": ["food-beverage"], "tags": ["Earnings Report", "Market Trends", "IDX", "Bullish"], "tickers": ["CLEO.JK"], "timestamp": "2025-01-14T12:01:28", "title": "Cleo Aims for Double-Digit Growth by 2025 with Sustainable Expansion Strategies."}, {"body": "Multipolar divested 37.50 million shares of PT Multipolar Technology Tbk, reducing its stake from 87% to 85%, while other notable transactions included PT Sarana Kelola Investa selling 300,700 shares of PT Meratus Jasa Prima Tbk and HSBC-Fund Svs A/C Chengdong Investment Corp-Self decreasing its stake in PT Bumi Resources Tbk by 4.28 million shares. Meanwhile, individual investors such as Manoj Pitamber Nanwani and John Herry Teja increased their stakes in PT Wintermar Offshore Marine Tbk and PT Menn Teknologi Indonesia Tbk, respectively.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "technology", "source": "https://www.idnfinancials.com/news/52044/multipolar-sells-shares-multipolar-technology-mlpt", "sub_sector": ["software-it-services", "transportation-infrastructure", "basic-materials", "oil-gas-coal", "oil-gas-coal", "technology-hardware-equipment", "food-staples-retailing"], "tags": ["IDX", "Market Trends", "Market Sentiment", "Executive Changes", "Neutral"], "tickers": ["MLPT.JK", "KARW.JK", "BRMS.JK", "BUMI.JK", "WINS.JK", "MENN.JK", "MLPL.JK"], "timestamp": "2025-01-14T11:34:02", "title": "Multipolar divests 37.5 million shares, triggering changes in ownership stakes across various Indonesian companies."}, {"body": "PT Techno9 Indonesia Tbk (TECH) aims to achieve 20-30% revenue growth in 2025, driven by its cyber security and e-catalogue services, following a revenue of IDR 15 billion in 2024. In the first half of 2024, the company reported revenue of IDR 1.37 billion, with potential for securing new projects through its membership in the national public procurement agency's e-catalogue and business actor performance information system.", "dimension": {"dividend": 0, "financials": 2, "future": 2, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "technology", "source": "https://www.idnfinancials.com/news/52043/branch-cyber-security-sector", "sub_sector": ["technology-hardware-equipment", "food-beverage", "oil-gas-coal", "retailing", "heavy-constructions-civil-engineering", "heavy-constructions-civil-engineering", "financing-service", "oil-gas-coal", "oil-gas-coal", "basic-materials", "banks", "banks", "food-beverage", "oil-gas-coal", "insurance", "banks", "industrial-goods", "basic-materials", "investment-service", "food-staples-retailing", "food-beverage", "basic-materials", "holding-investment-companies", "properties-real-estate", "basic-materials", "utilities", "properties-real-estate", "industrial-goods", "banks", "insurance", "industrial-services", "multi-sector-holdings", "insurance", "properties-real-estate", "transportation", "automobiles-components", "basic-materials", "banks", "banks", "banks", "apparel-luxury-goods", "consumer-services", "banks", "banks", "banks", "banks", "banks", "banks", "banks", "holding-investment-companies", "banks", "basic-materials", "software-it-services", "oil-gas-coal", "properties-real-estate", "financing-service", "banks", "insurance", "multi-sector-holdings", "banks", "oil-gas-coal", "transportation", "food-beverage", "banks", "banks", "logistics-deliveries", "healthcare-equipment-providers", "banks", "media-entertainment", "banks", "multi-sector-holdings", "banks", "banks", "banks", "retailing", "consumer-services", "automobiles-components", "utilities", "banks", "basic-materials", "basic-materials", "properties-real-estate", "oil-gas-coal", "food-beverage", "telecommunication", "banks", "banks", "food-beverage", "software-i