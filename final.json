[{"body": "International tourist arrivals in Indonesia rose 17.29% to 1.09 million in November 2024, with Malaysia being the top country of origin, accounting for 174,265 visits, a 22.94% increase from November 2023. Tourist visits from ASEAN countries reached 383,038, the highest among all regions, followed by Asia with 319,508 visits, and Europe with 158,444 visits.", "dimension": {"dividend": 0, "financials": 1, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "consumer-cyclicals", "source": "https://www.idnfinancials.com/news/51914/international-tourist-visits-majority-malaysia", "sub_sector": ["consumer-services"], "tags": ["Bullish"], "tickers": [], "timestamp": "2025-01-03T14:02:13", "title": "International tourist arrivals in Jakarta increase by 17.29% in November 2024, with Malaysia being the top country of origin."}, {"body": "PT Adaro Andalan Indonesia TBK (AADI) led the top five value trading in December 2024 with a trading value of Rp42.39 trillion, followed by PT Bank Rakyat Indonesia TBK (BBRI) with a trading value of Rp21.67 trillion, and PT Bank Central Asia TBK (BBCA) with a trading value of Rp17.06 trillion. AADI's stock price increased 21.05% to close at Rp8,050 on January 2, after its initial public offering at Rp5,550 per share on December 5.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 2, "valuation": 2}, "score": 75, "sector": "financials", "source": "https://www.idnfinancials.com/news/51913/adaro-issuers-trading", "sub_sector": ["banks", "banks"], "tags": ["IDX", "IDX Composite", "IPO", "Market Trends", "Stock Splits", "Bullish"], "tickers": ["BBRI.JK", "BBCA.JK"], "timestamp": "2025-01-03T13:31:58", "title": "Adaro Group issuers dominate top five value trading in December 2024, outperforming major national banking stocks."}, {"body": "PT Waskita Karya Tbk (WSKT) will increase its capital in subsidiary PT Kresna Kusuma Dyandra Marga (KKDM) through another subsidiary, PT Waskita Toll Road, with an investment of IDR 1.57 trillion, raising its stake to 91.83%. The capital raise will account for 13.6% of WSKT's total equity and 6.5% of PT Waskita Toll Road's total equity, aiming to reinforce KKDM's operational performance, particularly in managing the Bekasi-Cawang-Kampung Melayu toll road.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 1}, "score": 75, "sector": "infrastructures", "source": "https://www.idnfinancials.com/news/51912/wskt-boost-subsidiarys-capital", "sub_sector": ["heavy-constructions-civil-engineering"], "tags": ["Mergers & Acquisitions", "IDX", "Bullish"], "tickers": ["WSKT.JK"], "timestamp": "2025-01-03T13:23:54", "title": "Waskita Karya's subsidiary to increase capital in Kresna Kusuma Dyandra Marga through toll road subsidiary."}, {"body": "PT MNC Kapital Indonesia Tbk (MNC) is set to issue shelf-registration bonds worth IDR 500 billion, with a target to raise IDR 555 billion, through three series of bonds with varying tenors and interest rates. If all bonds are fully sold, approximately IDR 298.29 billion will be used to repay existing bonds maturing in January 2025, with the remaining proceeds allocated towards working capital, business development, and operational improvements.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "financials", "source": "https://www.idnfinancials.com/news/51911/bcap-offer-idr-bonds", "sub_sector": ["holding-investment-companies", "food-beverage", "oil-gas-coal", "retailing", "heavy-constructions-civil-engineering", "heavy-constructions-civil-engineering", "financing-service", "oil-gas-coal", "oil-gas-coal", "basic-materials", "banks", "banks", "food-beverage", "oil-gas-coal", "insuran