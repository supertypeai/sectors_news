[{"body": "On September 19, foreign investors sold a net 629.42 million shares, with the largest contributor being PT GoTo Gojek Tokopedia Tbk, which saw a net sale of 1 billion shares. Meanwhile, foreign investors purchased shares in several companies, including PT Bank Rakyat Indonesia Tbk, PT Bank Negara Indonesia Tbk, and PT Telkom Indonesia Tbk, with net volumes of 102.61 million, 53.16 million, and 52.16 million shares, respectively.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 0}, "sector": "financials", "source": "https://www.idnfinancials.com/news/50958/foreign-sell-shares-foreign-volume-plunges-shares", "sub_sector": ["banks", "software-it-services", "telecommunication"], "tags": ["Foreign Investor", "IDX", "Bearish"], "tickers": ["GOTO.JK", "BBRI.JK", "BBNI.JK", "TLKM.JK"], "timestamp": "2024-09-20T10:51:46", "title": "Foreign investors sell 629 million shares in Indonesian market on Thursday, led by digital company PT GoTo Gojek Tokopedia."}, {"body": "Several investors made significant changes to their holdings in various Indonesian companies, including PT Buana Lintas Lautan TBK, PT Energi Mega Persada TBK, and PT Wilton Makmur Indonesia TBK, resulting in changes to ownership percentages. Meanwhile, PT Sinar Mas Cakrawala increased its stake in PT Sinar Mas Multiartha TBK to 51.43%, and PT Elang Mahkota Teknologi TBK boosted its holding in PT Sarana Meditama Metropolitan TBK to 78.46%.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 0}, "sector": "basic-materials", "source": "https://www.idnfinancials.com/news/50957/majukarya-mandiri-sells-buana-lintas-lautan-bull-shares", "sub_sector": ["basic-materials", "healthcare-equipment-providers", "holding-investment-companies"], "tags": ["Mergers & Acquisitions", "Executive Changes", "IDX", "Bullish"], "tickers": ["BULL.JK", "ENRG.JK", "SQMI.JK", "SMMA.JK", "EMTK.JK", "SAME.JK"], "timestamp": "2024-09-20T10:48:36", "title": "Multiple companies in Indonesia undergo changes in ownership and shareholdings."}, {"body": "PT Master Print Tbk, a company engaged in trading and distribution of industrial packaging equipment, plans to raise IDR 58.73 billion through an initial public offering of 435 million shares, priced between IDR 125 and IDR 135 per share. The company will use 46% of the IPO proceeds for inorganic growth through acquisitions and the remaining 54% for working capital, with the IPO scheduled to take place from September 20-24, 2024, and listing on the Indonesia Stock Exchange on October 8, 2024.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 2}, "sector": "industrials", "source": "https://www.idnfinancials.com/news/50956/master-print-offers-shares-ipo", "sub_sector": ["industrial-goods"], "tags": ["IPO", "IDX", "IDX Composite", "Bullish"], "tickers": [], "timestamp": "2024-09-20T10:44:23", "title": "PT Master Print Tbk to Raise IDR 58.73 Billion Through Initial Public Offering of 435 Million Shares"}, {"body": "Foreign investors sold a significant amount of shares in several Indonesian companies, including PT GoTo Gojek Tokopedia Tbk (net volume: -456.93 million shares), PT Bukalapak.com Tbk (-167.58 million shares), and PT Bumi Resources Tbk (-92.07 million shares). Meanwhile, they purchased shares in companies such as PT Buana Lintas Lautan Tbk (net volume: 71 million shares), PT Haloni Jane Tbk (57.02 million shares), and PT Astra International Tbk (48.68 million shares).", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 0}, "sector": "healthcare", "source": "https://www.idnfinancials.com/news/50955/gojek-tokopedia-sold-foreign-volume-closing-shares", "sub_sector": ["healthcare-equipment-providers", "oil-gas-coal", "software-it-services"], "tags": ["Foreign Investor", "IDX", "Market Sentiment", "Bearish"], "tickers": ["GOTO.JK", "BUKA.JK", "BULL.JK", "HALO.JK"], "timestamp": "2024-09-20T10:34:33", "title": "Foreign Investors Sell Significant Shares in Indonesian Companies, Including GoTo and Bukalapak."}, {"body": "PT Solusi Sinergi Digital Tbk (Surge) and PT Indonesia Connectivity Investasi (Iconvest) have collaborated to develop affordable internet services for communities, leveraging Iconvest's 3 million homepasses and 7,000 km connectivity network along railway lines. The partnership aims to become a catalyst for Indonesia's digital economy growth by distributing reliable and affordable internet networks, driving operational efficiency and sustainable green energy transformation.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 0, "sustainability": 2, "technical": 0, "valuation": 0}, "sector": "technology", "source": "https://www.idnfinancials.com/news/50954/developing-affordable-internet-services-wifi-partners-pln-subsidiary", "sub_sector": ["software-it-services"], "tags": ["Fintech", "IDX", "Market Trends", "Clean Energy", "Bullish"], "tickers": ["WIFI.JK"], "timestamp": "2024-09-20T09:45:25", "title": "PT Solusi Sinergi Digital and PT Indonesia Connectivity Investasi collaborate to develop affordable internet services in Indonesia."}, {"body": "PT Mandiri Herindo Adiperkasa Tbk, a coal distribution company, plans to conduct a share buyback of up to 10% of its total issued and paid-up capital, with a budget of IDR 200 billion, aiming to enhance investor trust in the company's fundamental value. The buyback is expected to take place from October 23, 2024, to October 22, 2025, following approval from an extraordinary general meeting of shareholders on October 22, 2024.", "dimension": {"dividend": 0, "financials": 1, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 2}, "sector": "energy", "source": "https://www.idnfinancials.com/news/50948/maha-set-shares-buyback-idr-budget", "sub_sector": ["oil-gas-coal"], "tags": ["Buyback", "IDX", "IDX Composite", "Bullish"], "tickers": ["MAHA.JK"], "timestamp": "2024-09-19T11:24:33", "title": "Mandiri Herindo Adiperkasa to Conduct Share Buyback Worth IDR 200 Billion to Enhance Investor Trust."}, {"body": "Foreign investors sold a net 987.60 million shares on Tuesday, September 17, with major contributors including PT GoTo Gojek Tokopedia Tbk, PT Smartfren Telecom Tbk, and PT Bukalapak.com Tbk. Meanwhile, foreign investors bought a significant number of shares in companies such as PT Bumi Resources Tbk, PT Bumi Resources Minerals Tbk, PT Bank Syariah Indonesia Tbk, and real estate development companies PT Intiland Development Tbk and PT Summarecon Agung Tbk.", "dimension": {"dividend": 0, "financials": 0, "future": 0, "management": 0, "ownership": 2, "sustainability": 0, "technical": 0, "valuation": 0}, "sector": "financials", "source": "https://www.idnfinancials.com/news/50942/transactions-selling-foreign-shares-surges-foreign-volume-drops-shares", "sub_sector": ["banks", "basic-materials", "oil-gas-coal"], "tags": ["Foreign Investor", "IDX", "Sharia Economy", "Mixed"], "tickers": ["GOTO.JK", "FREN.JK", "BUKA.JK", "BRMS.JK", "BUMI.JK", "BRIS.JK", "DILD.JK", "SMRA.JK"], "timestamp": "2024-09-18T17:44:52", "title": "Foreign investors in Indonesia sell 5.45 billion shares, led by sales of Goto Gojek Tokopedia and other major companies."}, {"body": "PT Astra International's electric vehicle (EV) sales reached 9.3% of its total four-wheeled vehicle sales in the first semester of 2024, up from 7% at the end of 2023, with hybrid EV cars contributing 68-70% to the XEV market. To compete with Chinese EV players, Astra plans to launch 3 new battery EV models in the next 2 years, supported by a good network quality aftersales and expansion of its EV charging infrastructure.", "dimens