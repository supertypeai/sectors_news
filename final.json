[{"body": "PT Industri Jamu dan Farmasi Sido Muncul Tbk (SIDO) recorded the highest net profit margin of 29.62% among its 13 competitors in the pharmaceutical industry, with revenue of IDR 2.62 trillion and net profit of IDR 778.11 billion. PT Kalbe Farma Tbk (KLBF) followed with a net profit margin of 9.81%, while PT Tempo Scan Pacific Tbk (TMP) and PT Soho Global Health Tbk (SOHO) posted net profit margins of 10.67% and 4.57%, respectively.", "dimension": {"dividend": 0, "financials": 2, "future": 0, "management": 0, "ownership": 0, "sustainability": 0, "technical": 0, "valuation": 0}, "score": 75, "sector": "healthcare", "source": "https://www.idnfinancials.com/news/51687/pharmaceutical-industry-sido-recorded-profit-quarter", "sub_sector": ["pharmaceuticals-health-care-research", "pharmaceuticals-health-care-research", "pharmaceuticals-health-care-research", "pharmaceuticals-health-care-research"], "tags": ["Earnings Report", "Financial Ratios", "IDX", "Market Analysis", "Bullish"], "tickers": ["SIDO.JK", "KLBF.JK", "TSPC.JK", "SOHO.JK"], "timestamp": "2024-12-09T16:43:25", "title": "PT Industri Jamu dan Farmasi Sido Muncul records highest net profit margin among pharmaceutical companies in Indonesia."}, {"body": "PT Integra Indocabinet Tbk (WOOD) partners with PT Ciputra Development Tbk (CTRA) to develop a green housing project on its landbank in East Java, expected to bring in a new revenue stream aside from its existing processed wood manufacturing business. The project aims to fill the middle-class market demand for modern and affordable housing, with WOOD targeting to leverage its landbank's potential to increase revenue and profit.", "dimension": {"dividend": 0, "financials": 2, "future": 2, "management": 0, "ownership": 0, "sustainability": 2, "technical": 0, "valuation": 0}, "score": 75, "sector": "consumer-cyclicals", "source": "https://www.idnfinancials.com/news/51686/eyeing-income-source-wood-ctra-sidoarjo-landbank", "sub_sector": ["household-goods", "